/*
 * CuChulainn IDS v5.1 - TLS ClientHello Parser
 * Basic TLS detection with version parsing, SNI extraction,
 * and simple handshake anomaly heuristics.
 */

#include "protocol_parser.h"
#include <string.h>
#include <stdint.h>
#include <ctype.h>

static uint16_t read_u16(const uint8_t *p) {
    return ((uint16_t)p[0] << 8) | (uint16_t)p[1];
}

static int is_printable_hostname_char(unsigned char c) {
    return isalnum(c) || c == '-' || c == '.';
}

static int tls_extract_sni(const uint8_t *data, size_t len, char *out, size_t out_sz) {
    if (!data || !out || out_sz == 0 || len < 5) return -1;
    if (data[0] != 0x16) return -1;

    uint16_t record_len = read_u16(&data[3]);
    if ((size_t)record_len + 5 > len) return -1;
    if (len < 9) return -1;
    if (data[5] != 0x01) return -1; /* ClientHello */

    size_t off = 9; /* handshake header starts at 5, body starts at 9 */
    if (off + 2 + 32 > len) return -1;

    off += 2;   /* client version */
    off += 32;  /* random */

    if (off + 1 > len) return -1;
    uint8_t session_id_len = data[off++];
    if (off + session_id_len > len) return -1;
    off += session_id_len;

    if (off + 2 > len) return -1;
    uint16_t cipher_len = read_u16(&data[off]);
    off += 2;
    if (off + cipher_len > len) return -1;
    off += cipher_len;

    if (off + 1 > len) return -1;
    uint8_t comp_len = data[off++];
    if (off + comp_len > len) return -1;
    off += comp_len;

    if (off + 2 > len) return -1;
    uint16_t ext_len = read_u16(&data[off]);
    off += 2;
    if (off + ext_len > len) return -1;

    size_t ext_end = off + ext_len;
    while (off + 4 <= ext_end && off + 4 <= len) {
        uint16_t ext_type = read_u16(&data[off]);
        uint16_t ext_size = read_u16(&data[off + 2]);
        off += 4;

        if (off + ext_size > ext_end || off + ext_size > len) return -1;

        if (ext_type == 0x0000) { /* server_name */
            if (ext_size < 5) return -1;

            size_t sni_off = off;
            uint16_t list_len = read_u16(&data[sni_off]);
            sni_off += 2;
            if (sni_off + list_len > off + ext_size) return -1;
            if (sni_off + 3 > len) return -1;

            uint8_t name_type = data[sni_off++];
            uint16_t name_len = read_u16(&data[sni_off]);
            sni_off += 2;

            if (name_type != 0) return -1;
            if (sni_off + name_len > off + ext_size) return -1;

            size_t copy_len = name_len;
            if (copy_len >= out_sz) copy_len = out_sz - 1;

            for (size_t i = 0; i < copy_len; i++) {
                unsigned char c = data[sni_off + i];
                out[i] = is_printable_hostname_char(c) ? (char)c : '?';
            }
            out[copy_len] = '\0';
            return 0;
        }

        off += ext_size;
    }

    return -1;
}

int parse_tls(const uint8_t *data, size_t len, protocol_ctx_t *ctx) {
    if (!data || !ctx || len < 9) return -1;
    if (data[0] != 0x16) return -1; /* handshake record */

    ctx->proto = PROTO_TLS;
    ctx->flags = 0;
    memset(ctx->domain, 0, sizeof(ctx->domain));

    /* record version */
    uint16_t record_ver = read_u16(&data[1]);
    if (record_ver < 0x0301 || record_ver > 0x0304) {
        ctx->flags += 2;
    }

    /* handshake type */
    if (data[5] != 0x01) { /* not ClientHello */
        ctx->flags += 1;
    }

    if (tls_extract_sni(data, len, ctx->domain, sizeof(ctx->domain)) == 0) {
        if (strlen(ctx->domain) > 64) ctx->flags += 2;
        if (strstr(ctx->domain, "..") != NULL) ctx->flags += 3;
        if (strchr(ctx->domain, '?') != NULL) ctx->flags += 2;
    } else {
        ctx->flags += 1; /* no SNI or parse failed */
    }

    return 0;
}

bool tls_is_malicious(const protocol_ctx_t *ctx) {
    if (!ctx) return false;

    if (ctx->flags >= 4) return true;

    if (ctx->domain[0]) {
        if (strlen(ctx->domain) > 64) return true;
        if (strstr(ctx->domain, "..") != NULL) return true;
    }

    return false;
}
