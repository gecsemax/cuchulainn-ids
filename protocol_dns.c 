#include "protocol_parser.h"
#include <string.h>
#include <stdint.h>
#include <stdbool.h>
#include <ctype.h>
#include <math.h>
#include <stdio.h>

#define DNS_HDR_LEN 12
#define DNS_MAX_NAME_WIRE 255
#define DNS_MAX_LABEL_LEN 63
#define DNS_MAX_POINTER_HOPS 16

/* Parser error codes for debugging and telemetry */
typedef enum dns_parse_error {
    DNS_OK = 0,
    DNS_ERR_NULL = -1,
    DNS_ERR_SHORT_HEADER = -2,
    DNS_ERR_NO_QUESTION = -3,
    DNS_ERR_BAD_QNAME = -4,
    DNS_ERR_TRUNCATED_QUESTION = -5,
    DNS_ERR_NAME_TOO_LONG = -6,
    DNS_ERR_LABEL_TOO_LONG = -7,
    DNS_ERR_BAD_POINTER = -8,
    DNS_ERR_POINTER_LOOP = -9,
    DNS_ERR_RESERVED_LABEL_BITS = -10,
    DNS_ERR_OUTPUT_TRUNC = -11
} dns_parse_error_t;

/* QCLASS and QTYPE values (RFC 1035 + common types) */
enum {
    DNS_CLASS_IN   = 1,
    DNS_CLASS_CS   = 2,
    DNS_CLASS_CH   = 3,
    DNS_CLASS_HS   = 4,
    DNS_QCLASS_ANY = 255
};

enum {
    DNS_TYPE_A      = 1,
    DNS_TYPE_NS     = 2,
    DNS_TYPE_MD     = 3,
    DNS_TYPE_MF     = 4,
    DNS_TYPE_CNAME  = 5,
    DNS_TYPE_SOA    = 6,
    DNS_TYPE_MB     = 7,
    DNS_TYPE_MG     = 8,
    DNS_TYPE_MR     = 9,
    DNS_TYPE_NULL   = 10,
    DNS_TYPE_WKS    = 11,
    DNS_TYPE_PTR    = 12,
    DNS_TYPE_HINFO  = 13,
    DNS_TYPE_MINFO  = 14,
    DNS_TYPE_MX     = 15,
    DNS_TYPE_TXT    = 16,
    DNS_TYPE_AAAA   = 28,
    DNS_TYPE_SRV    = 33,
    DNS_TYPE_ANY    = 255
};

static uint16_t read_u16_be(const uint8_t *p) {
    return (uint16_t)(((uint16_t)p[0] << 8) | p[1]);
}

static float dns_entropy_score_buf(const char *s) {
    if (!s || !*s) return 0.0f;

    int freq[256] = {0};
    size_t len = 0;

    for (const unsigned char *p = (const unsigned char *)s; *p; ++p) {
        freq[*p]++;
        len++;
    }

    if (len == 0) return 0.0f;

    float h = 0.0f;
    const float inv_log2 = 1.0f / logf(2.0f);
    for (int i = 0; i < 256; i++) {
        if (!freq[i]) continue;
        float prob = (float)freq[i] / (float)len;
        h -= prob * (logf(prob) * inv_log2);
    }
    return h;
}

static void dns_ascii_lower(char *s) {
    if (!s) return;
    for (; *s; ++s) {
        *s = (char)tolower((unsigned char)*s);
    }
}

static int dns_count_labels(const char *domain) {
    if (!domain || !*domain) return 0;
    if (strcmp(domain, ".") == 0) return 0;
    int count = 1;
    for (const char *p = domain; *p; ++p) {
        if (*p == '.') count++;
    }
    return count;
}

static int dns_longest_label(const char *domain) {
    int max_len = 0, cur = 0;
    if (!domain || !*domain) return 0;
    if (strcmp(domain, ".") == 0) return 0;

    for (const char *p = domain;; ++p) {
        if (*p == '.' || *p == '\0') {
            if (cur > max_len) max_len = cur;
            cur = 0;
            if (*p == '\0') break;
        } else {
            cur++;
        }
    }
    return max_len;
}

static float dns_left_label_entropy(const char *domain) {
    if (!domain || !*domain || strcmp(domain, ".") == 0) return 0.0f;

    char label[64];
    size_t i = 0;
    while (domain[i] && domain[i] != '.' && i < sizeof(label) - 1) {
        label[i] = domain[i];
        i++;
    }
    label[i] = '\0';
    return dns_entropy_score_buf(label);
}

static int dns_digit_count(const char *s) {
    int n = 0;
    if (!s) return 0;
    for (; *s; ++s) {
        if (isdigit((unsigned char)*s)) n++;
    }
    return n;
}

static bool dns_is_ldh_domain(const char *domain) {
    if (!domain || !*domain) return false;

    int label_len = 0;
    for (const unsigned char *p = (const unsigned char *)domain; ; ++p) {
        unsigned char c = *p;
        if (c == '.' || c == '\0') {
            if (label_len == 0) return false;
            if (*(p - 1) == '-') return false;
            label_len = 0;
            if (c == '\0') break;
            continue;
        }

        if (label_len == 0 && !isalpha(c) && !isdigit(c))
            return false;
        if (!(isalnum(c) || c == '-'))
            return false;

        label_len++;
        if (label_len > DNS_MAX_LABEL_LEN)
            return false;
    }

    return true;
}

static bool dns_has_suspicious_charset(const char *domain) {
    if (!domain || !*domain) return false;

    for (const unsigned char *p = (const unsigned char *)domain; *p; ++p) {
        unsigned char c = *p;
        if (isalnum(c) || c == '.' || c == '-') continue;
        return true;
    }

    return false;
}

static void dns_reason_append(char *buf, size_t buf_sz, const char *reason) {
    if (!buf || buf_sz == 0 || !reason || !*reason) return;

    size_t used = strlen(buf);
    if (used >= buf_sz - 1) return;

    if (used == 0) {
        (void)snprintf(buf, buf_sz, "%s", reason);
    } else {
        (void)snprintf(buf + used, buf_sz - used, ",%s", reason);
    }
}

static const char *dns_qtype_to_string(uint16_t qtype) {
    switch (qtype) {
        case DNS_TYPE_A:     return "A";
        case DNS_TYPE_NS:    return "NS";
        case DNS_TYPE_MD:    return "MD";
        case DNS_TYPE_MF:    return "MF";
        case DNS_TYPE_CNAME: return "CNAME";
        case DNS_TYPE_SOA:   return "SOA";
        case DNS_TYPE_MB:    return "MB";
        case DNS_TYPE_MG:    return "MG";
        case DNS_TYPE_MR:    return "MR";
        case DNS_TYPE_NULL:  return "NULL";
        case DNS_TYPE_WKS:   return "WKS";
        case DNS_TYPE_PTR:   return "PTR";
        case DNS_TYPE_HINFO: return "HINFO";
        case DNS_TYPE_MINFO: return "MINFO";
        case DNS_TYPE_MX:    return "MX";
        case DNS_TYPE_TXT:   return "TXT";
        case DNS_TYPE_AAAA:  return "AAAA";
        case DNS_TYPE_SRV:   return "SRV";
        case DNS_TYPE_ANY:   return "ANY";
        default:             return "UNKNOWN";
    }
}

static const char *dns_qclass_to_string(uint16_t qclass) {
    switch (qclass) {
        case DNS_CLASS_IN:   return "IN";
        case DNS_CLASS_CS:   return "CS";
        case DNS_CLASS_CH:   return "CH";
        case DNS_CLASS_HS:   return "HS";
        case DNS_QCLASS_ANY: return "ANY";
        default:             return "UNKNOWN";
    }
}

static const char *dns_parse_error_to_string(dns_parse_error_t err) {
    switch (err) {
        case DNS_OK:                    return "ok";
        case DNS_ERR_NULL:              return "null_input";
        case DNS_ERR_SHORT_HEADER:      return "short_header";
        case DNS_ERR_NO_QUESTION:       return "no_question";
        case DNS_ERR_BAD_QNAME:         return "bad_qname";
        case DNS_ERR_TRUNCATED_QUESTION:return "truncated_question";
        case DNS_ERR_NAME_TOO_LONG:     return "name_too_long";
        case DNS_ERR_LABEL_TOO_LONG:    return "label_too_long";
        case DNS_ERR_BAD_POINTER:       return "bad_pointer";
        case DNS_ERR_POINTER_LOOP:      return "pointer_loop";
        case DNS_ERR_RESERVED_LABEL_BITS:return "reserved_label_bits";
        case DNS_ERR_OUTPUT_TRUNC:      return "output_trunc";
        default:                        return "unknown_error";
    }
}

/* Decode QNAME from wire format with compression support. */
static dns_parse_error_t dns_extract_qname_safe(const uint8_t *msg, size_t len, size_t qoff,
                                                char *out, size_t out_sz, size_t *consumed) {
    if (!msg || !out || out_sz == 0 || !consumed) return DNS_ERR_NULL;
    if (len < DNS_HDR_LEN || qoff >= len) return DNS_ERR_BAD_QNAME;

    size_t cur = qoff;
    size_t out_pos = 0;
    size_t name_wire_len = 0;
    size_t jumps = 0;
    bool jumped = false;
    *consumed = 0;
    out[0] = '\0';

    while (cur < len) {
        uint8_t octet = msg[cur];

        if (octet == 0) {
            if (!jumped) {
                *consumed = (cur - qoff) + 1;
            }
            if (out_pos == 0) {
                if (out_sz < 2) return DNS_ERR_OUTPUT_TRUNC;
                out[0] = '.';
                out[1] = '\0';
            } else {
                out[out_pos] = '\0';
            }
            name_wire_len++;
            if (name_wire_len > DNS_MAX_NAME_WIRE) return DNS_ERR_NAME_TOO_LONG;
            return DNS_OK;
        }

        if ((octet & 0xC0) == 0xC0) {
            if (cur + 1 >= len) return DNS_ERR_BAD_POINTER;

            uint16_t ptr = (uint16_t)(((octet & 0x3F) << 8) | msg[cur + 1]);
            if (ptr >= len) return DNS_ERR_BAD_POINTER;
            if (ptr >= cur) return DNS_ERR_POINTER_LOOP;
            if (++jumps > DNS_MAX_POINTER_HOPS) return DNS_ERR_POINTER_LOOP;

            if (!jumped) {
                *consumed = (cur - qoff) + 2;
                jumped = true;
            }

            cur = ptr;
            continue;
        }

        if ((octet & 0xC0) != 0x00) return DNS_ERR_RESERVED_LABEL_BITS;
        if (octet > DNS_MAX_LABEL_LEN) return DNS_ERR_LABEL_TOO_LONG;

        size_t label_len = octet;
        cur++;

        if (cur + label_len > len) return DNS_ERR_BAD_QNAME;
        if (name_wire_len + 1 + label_len > DNS_MAX_NAME_WIRE) return DNS_ERR_NAME_TOO_LONG;

        if (out_pos != 0) {
            if (out_pos + 1 >= out_sz) return DNS_ERR_OUTPUT_TRUNC;
            out[out_pos++] = '.';
        }

        for (size_t i = 0; i < label_len; i++) {
            unsigned char c = msg[cur + i];
            if (out_pos + 1 >= out_sz) return DNS_ERR_OUTPUT_TRUNC;
            out[out_pos++] = isprint(c) ? (char)c : '?';
        }

        name_wire_len += 1 + label_len;
        cur += label_len;
    }

    return DNS_ERR_BAD_QNAME;
}

/* Main DNS parser entry. */
int parse_dns(const uint8_t *data, size_t len, protocol_ctx_t *ctx) {
    if (!ctx) return DNS_ERR_NULL;

    memset(ctx->domain, 0, sizeof(ctx->domain));
    ctx->proto = PROTO_DNS;
    ctx->flags = 0;
    ctx->entropy = 0.0f;
    ctx->qtype = 0;
    ctx->qclass = 0;
    ctx->suspicion_score = 0;
    ctx->suspicion_reason[0] = '\0';
    ctx->dns_error = DNS_OK;

    if (!data) {
        ctx->dns_error = DNS_ERR_NULL;
        return ctx->dns_error;
    }

    if (len < DNS_HDR_LEN) {
        ctx->dns_error = DNS_ERR_SHORT_HEADER;
        return ctx->dns_error;
    }

    ctx->flags = read_u16_be(&data[2]);

    uint16_t qdcount = read_u16_be(&data[4]);
    if (qdcount == 0) {
        ctx->dns_error = DNS_ERR_NO_QUESTION;
        return ctx->dns_error;
    }

    size_t consumed = 0;
    ctx->dns_error = dns_extract_qname_safe(data, len, DNS_HDR_LEN,
                                            ctx->domain, sizeof(ctx->domain), &consumed);
    if (ctx->dns_error != DNS_OK) {
        return ctx->dns_error;
    }

    if (DNS_HDR_LEN + consumed + 4 > len) {
        ctx->dns_error = DNS_ERR_TRUNCATED_QUESTION;
        return ctx->dns_error;
    }

    ctx->qtype  = read_u16_be(&data[DNS_HDR_LEN + consumed]);
    ctx->qclass = read_u16_be(&data[DNS_HDR_LEN + consumed + 2]);

    dns_ascii_lower(ctx->domain);
    ctx->entropy = dns_entropy_score_buf(ctx->domain);

    ctx->dns_error = DNS_OK;
    return DNS_OK;
}

/* Suspicion scoring with reasons, tuned for low false positives. */
int dns_suspicion_score(protocol_ctx_t *ctx) {
    if (!ctx) return 0;

    ctx->suspicion_score = 0;
    ctx->suspicion_reason[0] = '\0';

    if (!ctx->domain[0] || strcmp(ctx->domain, ".") == 0) {
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "empty_or_root");
        return 0;
    }

    size_t domain_len = strlen(ctx->domain);
    int labels = dns_count_labels(ctx->domain);
    int longest = dns_longest_label(ctx->domain);
    int digits = dns_digit_count(ctx->domain);
    float digit_ratio = domain_len ? ((float)digits / (float)domain_len) : 0.0f;
    float total_entropy = ctx->entropy;
    float left_entropy = dns_left_label_entropy(ctx->domain);
    bool weird_charset = dns_has_suspicious_charset(ctx->domain);
    bool ldh_only = dns_is_ldh_domain(ctx->domain);

    int score = 0;
    int strong = 0;

    if (domain_len >= 65) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "long_domain");
    }
    if (domain_len >= 90) {
        score += 1;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_long_domain");
    }

    if (longest >= 30) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "long_label");
    }
    if (longest >= 40) {
        score += 1;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_long_label");
    }

    if (labels >= 6) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "many_labels");
    }
    if (labels >= 8) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_many_labels");
    }

    if (left_entropy >= 3.6f) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "high_left_entropy");
    }
    if (left_entropy >= 4.1f) {
        score += 2;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_high_left_entropy");
    }

    if (total_entropy >= 4.15f) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "high_total_entropy");
    }
    if (total_entropy >= 4.45f) {
        score += 1;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_high_total_entropy");
    }

    if (digit_ratio >= 0.35f) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "digit_heavy");
    }
    if (digit_ratio >= 0.50f) {
        score += 1;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "very_digit_heavy");
    }

    if (weird_charset) {
        score += 2;
        strong++;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "non_ldh_chars");
    }

    if (!ldh_only) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "non_ldh_domain");
    }

    if (strstr(ctx->domain, "xn--") != NULL && left_entropy >= 4.0f) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "punycode_plus_entropy");
    }

    switch (ctx->qtype) {
        case DNS_TYPE_TXT:
            score += 1;
            dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                              "txt_query");
            if (left_entropy >= 3.6f || longest >= 30) {
                score += 1;
                strong++;
                dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                                  "txt_plus_encoded_subdomain");
            }
            break;

        case DNS_TYPE_NULL:
            score += 2;
            strong++;
            dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                              "null_query");
            break;

        case DNS_TYPE_ANY:
            score += 1;
            dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                              "any_query");
            break;

        case DNS_TYPE_CNAME:
            if (left_entropy >= 4.1f && longest >= 30) {
                score += 1;
                dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                                  "cname_plus_encoded_subdomain");
            }
            break;

        case DNS_TYPE_A:
        case DNS_TYPE_AAAA:
        case DNS_TYPE_MX:
        case DNS_TYPE_NS:
        case DNS_TYPE_PTR:
            break;

        default:
            if (left_entropy >= 4.1f && longest >= 30) {
                score += 1;
                strong++;
                dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                                  "rare_type_plus_encoded_subdomain");
            }
            break;
    }

    if (ctx->qclass != DNS_CLASS_IN) {
        score += 1;
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "non_in_class");
    }

    if ((ctx->qtype == DNS_TYPE_A || ctx->qtype == DNS_TYPE_AAAA) && strong == 0) {
        ctx->suspicion_score = 0;
        if (ctx->suspicion_reason[0] == '\0') {
            dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                              "common_type_low_confidence");
        }
        return 0;
    }

    ctx->suspicion_score = score;

    if (ctx->suspicion_reason[0] == '\0') {
        dns_reason_append(ctx->suspicion_reason, sizeof(ctx->suspicion_reason),
                          "no_strong_indicators");
    }

    return score;
}

bool dns_is_malicious(const protocol_ctx_t *ctx) {
    if (!ctx) return false;

    protocol_ctx_t tmp = *ctx;
    int score = dns_suspicion_score(&tmp);

    if (score >= 6) return true;

    if (score >= 5) {
        if (tmp.qtype == DNS_TYPE_TXT ||
            tmp.qtype == DNS_TYPE_NULL ||
            tmp.qtype == DNS_TYPE_ANY) {
            return true;
        }
    }

    return false;
}
